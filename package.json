{
  "name": "markerlayer",
  "version": "0.2.3",
  "description": "Deterministic reference implementation of the EN 18144:2025 behavioural markers of harm for online gambling",
  "license": "MIT",
  "author": "DUOMIND S.R.L.",
  "homepage": "https://markerlayer.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markerlayer/markerlayer.git"
  },
  "bugs": {
    "url": "https://github.com/markerlayer/markerlayer/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "SPEC.md",
    "openapi.yaml",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
