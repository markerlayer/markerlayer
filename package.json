  "keywords": [
    "responsible-gambling",
    "markers-of-harm",
    "EN18144",
    "player-protection",
    "safer-gambling"
  ],
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
